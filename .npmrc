strict-peer-dependencies=false
auto-install-peers=true
# React Native / Metro requires transitive deps to be hoisted to root node_modules.
# pnpm's isolated linker (shamefully-hoist=false) hides them in the virtual store
# where Metro cannot find them. The server is unaffected — Node.js handles both.
# Equivalent to shamefully-hoist=true (React Native / Metro needs flat node_modules)
# but expanded so we can carve out exclusions:
# - webidl-conversions: dev-only v8 leaks into the mobile bundle and crashes
#   Hermes at startup. v8 unconditionally reads
#   SharedArrayBuffer.prototype.byteLength.get which Hermes does not expose.
#   Excluded so Metro falls through to the nested v5 that
#   whatwg-url-without-unicode (used by expo/src/winter/url.ts) depends on.
public-hoist-pattern[]=*
public-hoist-pattern[]=!webidl-conversions
engine-strict=true
