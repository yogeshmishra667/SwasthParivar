#!/usr/bin/env sh

# Pre-push: runs scripts/preflight.sh, which simulates a fresh checkout
# (wipes dist/, .tsbuildinfo, then runs every CI gate in order).
#
# This replaced an earlier hook that ran the same checks WITHOUT cleaning
# the working tree first. Stale build artefacts let failures pass locally
# that CI would catch — three audit-PR red-runs were the lesson.
#
# Skipping with `git push --no-verify` is allowed in emergencies only.
# To also run integration + docker locally, set PREFLIGHT_FULL=1.

set -e

if [ "${PREFLIGHT_FULL:-0}" = "1" ]; then
  exec bash scripts/preflight.sh --full
else
  exec bash scripts/preflight.sh
fi
