# Mobile env template. Copy to apps/mobile/.env and fill in.
# Only EXPO_PUBLIC_* keys reach the JS bundle. Server secrets belong
# in apps/server/.env, never here.

EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=

# Optional — overrides app.json's extra.apiBaseUrl when set.
# EXPO_PUBLIC_APP_ENV=development
# EXPO_PUBLIC_SENTRY_RELEASE=
