// SwasthParivar — Phase 1 schema (glucose only)
// Later phases extend this schema; do not remove fields without migration review.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Gender {
  male
  female
  other
}

enum Language {
  hi
  en
}

enum Condition {
  diabetes
  hypertension
  asthma
  cardiac
}

enum Tier {
  free
  premium
  family
}

enum GlucoseReadingType {
  fasting
  pre_meal
  post_meal
  random
  bedtime
}

enum ReadingSource {
  manual
  voice
  device
}

enum ReadingContext {
  normal
  festive
}

enum MedicationLogStatus {
  taken
  skipped
  missed_no_response
  delayed
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum MealCategory {
  light
  normal
  heavy_fried
}

enum FeedbackTone {
  celebrate
  neutral
  gentle_warn
  encourage
}

enum FeedbackType {
  first_reading
  post_log_compare
  streak_milestone
  critical_warn
  festive
}

enum InsightPatternType {
  spike
  trend
  meal_correlation
  anomaly
  cross_condition
}

enum InsightSeverityLevel {
  info
  warn
  critical
}

// FamilyLink lifecycle. A patient creates a `pending` invite for a
// guardian; the guardian moves it to `accepted` (or `declined`). Either
// side can `revoked` it later. Only `accepted` links are visible from
// /family endpoints.
enum FamilyLinkStatus {
  pending
  accepted
  declined
  revoked
}

// Sensitivity controls how loudly Silent Guardian (Phase 3) speaks to
// this specific guardian. Phase 2 stores it but never reads it; kept on
// the model so the Phase 3 migration is purely additive.
enum FamilyAlertSensitivity {
  low
  medium
  high
}

enum ChatRole {
  user
  assistant
  system
}

// Cost tier the chat router actually used to produce the assistant
// response. Tracked per message so cost dashboards and per-tier hit
// rates can be derived without recomputing routing on read.
enum ChatCostTier {
  template
  cached
  sonnet
}

// Source of a Silent Guardian signal (Phase 3 — Feature C). Phase 3
// scope is med_adherence + data_anomaly only; chat_sentiment /
// schedule_miss / activity_drop / cross_signal are deferred to Phase 4.
enum SignalSource {
  med_adherence
  data_anomaly
}

// What a fired GuardianAlert is about. `combined` = both a med-adherence
// and a trend concern in the same analysis window.
enum GuardianAlertType {
  trend_concern
  med_adherence
  combined
}

// Stored guardian-alert severity. `red` is reserved for Phase 4
// (SOS-adjacent); in Phase 3 the highest band is orange.
enum GuardianAlertSeverity {
  yellow
  orange
}

// Delivery channel a guardian alert was sent over. WhatsApp is a Phase 4
// addition — the enum is intentionally forward-compatible.
enum AlertChannel {
  push
  sms
  in_app
}

// ─────────────────────────────────────────────────────────────
// Users & Household (Phase 1)
// ─────────────────────────────────────────────────────────────

model Household {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("households")
}

model User {
  id                   String      @id @default(uuid()) @db.Uuid
  name                 String
  phone                String      @unique
  age                  Int
  gender               Gender?
  preferredLanguage    Language    @default(hi) @map("preferred_language")
  conditions           Condition[]
  timezone             String      @default("Asia/Kolkata")
  householdId          String      @map("household_id") @db.Uuid
  onboardingComplete   Boolean     @default(false) @map("onboarding_complete")
  onboardingStep       Int         @default(0) @map("onboarding_step")
  tier                 Tier        @default(free)
  timeAnomalyCount     Int         @default(0) @map("time_anomaly_count")
  // Admin soft-disable. `active=false` blocks the auth surface
  // (send-otp, verify-otp, refresh) so a deactivated patient cannot
  // start a new session. Existing access tokens stay valid until they
  // expire (≤1h) — full medical history is retained per DPDP and the
  // tier-downgrade retention rule. Toggled only by super_admin / ops
  // via /admin/users/:id/(deactivate|reactivate); every flip is audited
  // in `AdminAuditLog`. `deactivatedByAdminId` is a plain string (no
  // FK) because `User` and `AdminUser` live in disjoint auth domains
  // by design (CLAUDE.md "Admin / Ops console").
  active               Boolean     @default(true)
  deactivatedAt        DateTime?   @map("deactivated_at")
  deactivationReason   String?     @map("deactivation_reason")
  deactivatedByAdminId String?     @map("deactivated_by_admin_id") @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  household              Household              @relation(fields: [householdId], references: [id])
  glucoseReadings        GlucoseReading[]
  bpReadings             BPReading[]
  mealLogs               MealLog[]
  insights               InsightEvent[]
  medicationSchedules    MedicationSchedule[]
  medicationLogs         MedicationLog[]
  streak                 UserStreak?
  feedbackEvents         FeedbackEvent[]
  notificationState      NotificationState?
  emergencyContacts      EmergencyContact[]
  pushTokens             PushToken[]
  healthScores           HealthScore[]
  // Family links — a user can be the patient on some rows and the
  // guardian on others. Phase 2 ships the read-only dashboard; alerts
  // arrive in Phase 3.
  patientFamilyLinks     FamilyLink[]           @relation("PatientLinks")
  guardianFamilyLinks    FamilyLink[]           @relation("GuardianLinks")
  chatSessions           ChatSession[]
  chatMessages           ChatMessage[]
  // Silent Guardian (Phase 3 — Feature C). Signals are detected about a
  // patient; alerts have a patient side and a guardian side.
  silentGuardianSignals  SilentGuardianSignal[]
  patientGuardianAlerts  GuardianAlert[]        @relation("PatientAlerts")
  guardianGuardianAlerts GuardianAlert[]        @relation("GuardianAlerts")

  @@index([householdId])
  // Admin "show deactivated users" filter — partial-like coverage via
  // a regular b-tree on `active`. The selectivity is fine: > 99% of
  // rows are `active=true`, so the index pays off for the rare
  // `active=false` scan and is cheap on writes.
  @@index([active])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Family / Guardian links (Phase 2 step 7)
// ─────────────────────────────────────────────────────────────

// A FamilyLink connects one patient to one guardian (both `User` rows,
// possibly in different households). Phase 2 ships the read-only
// dashboard endpoint; alerts arrive in Phase 3 and reuse this same row.
// `visibleConditions` lets the patient hide e.g. cardiac history from a
// specific guardian without breaking the link.
model FamilyLink {
  id                String                 @id @default(uuid()) @db.Uuid
  patientId         String                 @map("patient_id") @db.Uuid
  guardianId        String                 @map("guardian_id") @db.Uuid
  // Free-text relationship label entered by the patient ("son",
  // "beti", "Mausi"). Not an enum — labels are user-facing copy.
  relationship      String?
  // Default-on so the Phase 3 alert pipeline doesn't require a
  // migration to start sending. Patient can flip per-guardian via the
  // privacy endpoint at any time.
  alertEnabled      Boolean                @default(true) @map("alert_enabled")
  // Subset of the patient's `conditions` array that this guardian can
  // see. Empty array = no conditions hidden, all are visible (default).
  // Non-empty = the dashboard filters to these conditions only.
  visibleConditions String[]               @default([]) @map("visible_conditions")
  alertSensitivity  FamilyAlertSensitivity @default(medium) @map("alert_sensitivity")
  status            FamilyLinkStatus       @default(pending)
  acceptedAt        DateTime?              @map("accepted_at")
  revokedAt         DateTime?              @map("revoked_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  patient  User @relation("PatientLinks", fields: [patientId], references: [id], onDelete: Cascade)
  guardian User @relation("GuardianLinks", fields: [guardianId], references: [id], onDelete: Cascade)

  // Only one link per (patient, guardian) pair regardless of status —
  // a re-invite after a revoke updates the existing row in place. The
  // controller surfaces FAMILY_LINK_EXISTS when an active row is
  // already there.
  @@unique([patientId, guardianId])
  @@index([guardianId, status])
  @@index([patientId, status])
  @@map("family_links")
}

model EmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  name         String
  phone        String
  relationship String
  priority     Int
  isGuardian   Boolean  @default(false) @map("is_guardian")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priority])
  @@map("emergency_contacts")
}

// ─────────────────────────────────────────────────────────────
// Readings (TimescaleDB hypertable — see migrations)
// ─────────────────────────────────────────────────────────────

model GlucoseReading {
  id                         String             @default(uuid()) @db.Uuid
  clientUuid                 String             @map("client_uuid") @db.Uuid
  userId                     String             @map("user_id") @db.Uuid
  valueMgDl                  Int                @map("value_mg_dl")
  readingType                GlucoseReadingType @map("reading_type")
  context                    ReadingContext     @default(normal)
  notes                      String?
  source                     ReadingSource
  measuredAt                 DateTime           @map("measured_at")
  streakCreditedTo           DateTime           @map("streak_credited_to") @db.Date
  // Anti-cheat flags raised by the streak engine for this reading
  // (e.g. ["same_value_3_consecutive"]). Stored for analytics; never
  // blocks save. Empty array when no flags raised.
  antiCheatFlags             Json               @default("[]") @map("anti_cheat_flags")
  // True when streak credit used server-received time instead of the
  // client-reported `measuredAt` (Patch #18 — fired when the user has
  // crossed time_anomaly_count >= 2). The reading's measuredAt remains
  // the patient-reported timestamp for medical fidelity.
  streakCreditedAtServerTime Boolean            @default(false) @map("streak_credited_at_server_time")
  version                    Int                @default(1)
  syncedAt                   DateTime?          @map("synced_at")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id, measuredAt])
  @@unique([clientUuid, measuredAt])
  @@index([userId, measuredAt])
  @@index([userId, readingType, measuredAt])
  @@index([userId, streakCreditedTo])
  @@map("glucose_readings")
}

// ─────────────────────────────────────────────────────────────
// BP (Phase 2)
// ─────────────────────────────────────────────────────────────

model BPReading {
  id         String         @default(uuid()) @db.Uuid
  clientUuid String         @map("client_uuid") @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  systolic   Int
  diastolic  Int
  pulse      Int?
  context    ReadingContext @default(normal)
  notes      String?
  source     ReadingSource
  measuredAt DateTime       @map("measured_at")
  version    Int            @default(1)
  syncedAt   DateTime?      @map("synced_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite primary key matches the TimescaleDB hypertable pattern
  // used on glucose_readings. Test setup calls `create_hypertable()`
  // after `prisma migrate deploy`; production wiring is the same.
  @@id([id, measuredAt])
  @@unique([clientUuid, measuredAt])
  @@index([userId, measuredAt])
  @@map("bp_readings")
}

// ─────────────────────────────────────────────────────────────
// Meal logs (Phase 2) — context for the meal-correlation detector
// ─────────────────────────────────────────────────────────────

model MealLog {
  id              String       @default(uuid()) @db.Uuid
  clientUuid      String       @map("client_uuid") @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  mealType        MealType     @map("meal_type")
  mealCategory    MealCategory @map("meal_category")
  foodDescription String?      @map("food_description")
  loggedAt        DateTime     @map("logged_at")
  version         Int          @default(1)
  syncedAt        DateTime?    @map("synced_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite primary key matches the TimescaleDB hypertable pattern.
  // Test setup calls `create_hypertable()` after `prisma migrate deploy`;
  // production wiring is the same as glucose_readings and bp_readings.
  @@id([id, loggedAt])
  @@unique([clientUuid, loggedAt])
  @@index([userId, loggedAt])
  @@index([userId, mealCategory, loggedAt])
  @@map("meal_logs")
}

// ─────────────────────────────────────────────────────────────
// Insights (Phase 2)
// ─────────────────────────────────────────────────────────────

model InsightEvent {
  id                 String               @default(uuid()) @db.Uuid
  userId             String               @map("user_id") @db.Uuid
  patternType        InsightPatternType   @map("pattern_type")
  // string[] rather than Condition[] — detectors may surface a category
  // (e.g. "glucose", "bp") that isn't a `Condition` enum value.
  conditionsInvolved String[]             @map("conditions_involved")
  severityScore      Int                  @map("severity_score") // 0-100
  severityLevel      InsightSeverityLevel @map("severity_level")
  messageKey         String               @map("message_key")
  messageParams      Json                 @default("{}") @map("message_params")
  // Reading ids that triggered this insight (JSON array of UUIDs).
  // Stored as JSON not String[] because mixed types possible later
  // (e.g. {glucose: [...], bp: [...]}).
  triggerReadings    Json                 @default("[]") @map("trigger_readings")
  evidence           Json                 @default("{}")
  // Confidence < 0.7 → still persisted but `acknowledged: false` and
  // suppressed from the mobile feed (analytics-only).
  confidence         Float                @default(1.0)
  acknowledged       Boolean              @default(false)
  helpful            Boolean?
  createdAt          DateTime             @default(now()) @map("created_at")
  expiresAt          DateTime?            @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite PK matches the TimescaleDB hypertable pattern. Test setup
  // calls `create_hypertable('insight_events', 'created_at')` after
  // `prisma migrate deploy`.
  @@id([id, createdAt])
  @@index([userId, createdAt])
  @@index([userId, acknowledged, createdAt])
  @@map("insight_events")
}

// ─────────────────────────────────────────────────────────────
// Health Score (Phase 2 step 5)
// ─────────────────────────────────────────────────────────────

model HealthScore {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  // 0-100, rounded integer from `computeHealthScore`.
  score           Int
  // Per-component scores: { logging, stability, trend, medication, streak }.
  // JSON not relation — schema-light and the consumer is a single mobile card.
  components      Json     @default("{}")
  // The date the score is *for* (user-local day). Unique per user per
  // day so the cron is idempotent: re-running for the same day updates
  // the row in place.
  computedForDate DateTime @map("computed_for_date") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, computedForDate])
  @@index([userId, computedForDate])
  @@map("health_scores")
}

// ─────────────────────────────────────────────────────────────
// Medication (Phase 1 — minimal)
// ─────────────────────────────────────────────────────────────

model MedicationSchedule {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  medicineName      String   @map("medicine_name")
  dosage            String?
  timeSlots         Json     @map("time_slots")
  condition         String?
  isCritical        Boolean  @default(false) @map("is_critical")
  photoUrl          String?  @map("photo_url")
  quantityRemaining Int?     @map("quantity_remaining")
  active            Boolean  @default(true)
  startedAt         DateTime @default(now()) @map("started_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs MedicationLog[]

  @@index([userId, active])
  @@map("medication_schedules")
}

model MedicationLog {
  id              String              @id @default(uuid()) @db.Uuid
  scheduleId      String              @map("schedule_id") @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  status          MedicationLogStatus
  scheduledFor    DateTime            @map("scheduled_for")
  respondedAt     DateTime?           @map("responded_at")
  skipReason      String?             @map("skip_reason")
  reminderCount   Int                 @default(0) @map("reminder_count")
  guardianAlerted Boolean             @default(false) @map("guardian_alerted")
  createdAt       DateTime            @default(now()) @map("created_at")

  schedule MedicationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledFor])
  @@index([scheduleId, scheduledFor])
  @@map("medication_logs")
}

// ─────────────────────────────────────────────────────────────
// Streaks & Feedback
// ─────────────────────────────────────────────────────────────

model UserStreak {
  userId             String    @id @map("user_id") @db.Uuid
  currentStreakDays  Int       @default(0) @map("current_streak_days")
  longestStreakDays  Int       @default(0) @map("longest_streak_days")
  lastLogDate        DateTime? @map("last_log_date") @db.Date
  streakStartedAt    DateTime? @map("streak_started_at")
  totalLogDays       Int       @default(0) @map("total_log_days")
  brokenStreakLength Int       @default(0) @map("broken_streak_length")
  graceUsedThisWeek  Int       @default(0) @map("grace_used_this_week")
  milestonesReached  Json      @default("[]") @map("milestones_reached")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model FeedbackEvent {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  readingId     String?      @map("reading_id") @db.Uuid
  feedbackType  FeedbackType @map("feedback_type")
  tone          FeedbackTone
  messageKey    String       @map("message_key")
  variantIndex  Int          @map("message_variant_index")
  messageParams Json         @map("message_params")
  shownAt       DateTime     @default(now()) @map("shown_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, shownAt])
  @@map("feedback_events")
}

model PushToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  token      String   @unique
  platform   String
  deviceId   String?  @map("device_id")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model NotificationState {
  userId                String    @id @map("user_id") @db.Uuid
  fatigueLevel          Int       @default(0) @map("fatigue_level")
  consecutiveIgnores    Int       @default(0) @map("consecutive_ignores")
  lastNotificationAt    DateTime? @map("last_notification_at")
  bestLogTimeFasting    String    @default("07:00") @map("best_log_time_fasting")
  bestLogTimePostMeal   String    @default("13:30") @map("best_log_time_post_meal")
  notificationHistory7d Json      @default("[]") @map("notification_history_7d")
  last3VariantIds       Json      @default("[]") @map("last_3_variant_ids")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_states")
}

// ─────────────────────────────────────────────────────────────
// AI Chat (Phase 3 — Feature A)
//
// Patient-facing Claude chat. Idempotent on `clientUuid` from mobile so
// retries during a network blip never produce duplicate rows.
// Retention: archived after 90 days, hard-deleted after 1 year via the
// CHAT_RETENTION_SWEEP cron (DPDP compliance, CC.11 §5 in phase3.md).
// ─────────────────────────────────────────────────────────────

model ChatSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  startedAt  DateTime  @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")
  language   Language
  archivedAt DateTime? @map("archived_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, startedAt(sort: Desc)])
  @@map("chat_sessions")
}

model ChatMessage {
  id                 String       @id @default(uuid()) @db.Uuid
  // Mobile-generated idempotency key. Unique so a retry with the same
  // clientUuid replays the persisted response instead of calling Claude
  // again. Distinct from server `id` so the server controls ordering.
  clientUuid         String       @unique @map("client_uuid") @db.Uuid
  version            Int          @default(1)
  sessionId          String       @map("session_id") @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  role               ChatRole
  content            String       @db.Text
  language           Language
  // Snapshot of which patient readings the assistant cited, so the
  // mobile bubble can link back to them without a join at render time.
  referencedReadings Json?        @map("referenced_readings")
  tokensInput        Int          @default(0) @map("tokens_input")
  tokensOutput       Int          @default(0) @map("tokens_output")
  costTier           ChatCostTier @map("cost_tier")
  responseLatencyMs  Int?         @map("response_latency_ms")
  flagged            Boolean      @default(false)
  // safety_filter_rejected | user_flagged | other — kept as free-form
  // text so we can introduce new audit categories without a migration.
  flagReason         String?      @map("flag_reason")
  safetyViolations   Json?        @map("safety_violations")
  createdAt          DateTime     @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId, createdAt])
  // Surfacing safety-flagged messages for the human audit queue. Partial
  // index would be ideal but Prisma doesn't model them; covered by
  // index on (flagged, createdAt) since the safety queue filter starts
  // with flagged=true.
  @@index([flagged, createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────────
// Silent Guardian (Phase 3 — Feature C)
//
// A SILENT_GUARDIAN_ANALYZE job (added in a later slice) detects
// concerns about a patient, scores each as a SilentGuardianSignal, and
// — when decayed signals aggregate past the alert threshold — fires a
// GuardianAlert to each linked guardian. Phase 3 scope: med-adherence
// and worsening-trend signals only.
// ─────────────────────────────────────────────────────────────

model SilentGuardianSignal {
  id     String @id @default(uuid()) @db.Uuid
  // The patient the signal is about.
  userId String @map("user_id") @db.Uuid

  signalSource     SignalSource @map("signal_source")
  // Machine string from the scorer, e.g. "med_missed_frequent",
  // "worsening_trend". Free-form so a new signal sub-type needs no
  // migration.
  signalType       String       @map("signal_type")
  // Structured numeric evidence from the analysis window. Never holds
  // patient free-text — the alert-explainer reads numbers only.
  rawEvidence      Json         @default("{}") @map("raw_evidence")
  // 0-100 contribution to aggregate risk, BEFORE decay.
  riskContribution Int          @map("risk_contribution")
  // Recomputed by the aggregator: 0.5 ^ (ageDays / 7), so a 7-day-old
  // signal is worth 0.5. Stored for traceability.
  decayFactor      Float        @default(1.0) @map("decay_factor")
  detectedAt       DateTime     @default(now()) @map("detected_at")
  // GuardianAlert.id if this signal contributed to a fired alert.
  consumedByAlert  String?      @map("consumed_by_alert") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, detectedAt(sort: Desc)])
  @@index([consumedByAlert])
  @@map("silent_guardian_signals")
}

model GuardianAlert {
  id         String @id @default(uuid()) @db.Uuid
  patientId  String @map("patient_id") @db.Uuid
  guardianId String @map("guardian_id") @db.Uuid

  alertType       GuardianAlertType     @map("alert_type")
  riskScore       Int                   @map("risk_score") // 0-100
  severity        GuardianAlertSeverity
  // Patient-facing copy, generated template-only by the alert-explainer
  // (no verbatim patient content — phase3.md C.2.4).
  title           String
  summary         String
  // Structured payload for mobile rendering.
  details         Json                  @default("{}")
  explanation     String                @db.Text
  suggestedAction String                @map("suggested_action") @db.Text
  // SilentGuardianSignal ids that produced this alert (audit trail).
  signalIds       String[]              @default([]) @map("signal_ids")
  // Channels the dispatch job actually sent over. Empty until dispatch.
  sentVia         AlertChannel[]        @default([]) @map("sent_via")
  pushDelivered   Boolean               @default(false) @map("push_delivered")
  smsDelivered    Boolean               @default(false) @map("sms_delivered")
  readAt          DateTime?             @map("read_at")
  // 'called_patient' | 'ignored' | 'helpful' | null — free-form so new
  // guardian actions need no migration.
  actionTaken     String?               @map("action_taken")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  patient  User @relation("PatientAlerts", fields: [patientId], references: [id], onDelete: Cascade)
  guardian User @relation("GuardianAlerts", fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([guardianId, createdAt(sort: Desc)])
  @@index([patientId, createdAt(sort: Desc)])
  @@index([severity, createdAt])
  // Backs the dispatch weekly-orange-cap lookup and the per-patient
  // daily summary — both filter on (guardianId, patientId, createdAt).
  @@index([guardianId, patientId, createdAt(sort: Desc)])
  // Backs the DAILY_GUARDIAN_SUMMARY yellow-alert count, which filters
  // on (guardianId, severity, createdAt).
  @@index([guardianId, severity, createdAt(sort: Desc)])
  @@map("guardian_alerts")
}

// ─────────────────────────────────────────────────────────────
// Admin / Ops console (out-of-phase operational tooling)
//
// Staff accounts for the internal admin console. Separate from `User`
// (patients/guardians) on purpose — different auth (email+password+TOTP
// vs phone OTP), different JWT secrets, different lifecycle. No relation
// to patient data; the console reaches patient rows through queries, not
// foreign keys. See docs/admin-dashboard-plan.md.
// ─────────────────────────────────────────────────────────────

enum AdminRole {
  super_admin
  ops
  support
  analyst
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole @default(analyst)
  // Soft-disable: an inactive account fails auth without losing its
  // audit history. Deactivation is preferred over deletion.
  active       Boolean   @default(true)
  // TOTP (2FA). `totpSecret` is base32, written at enrolment.
  // `totpEnabled` flips true only after the first code is confirmed;
  // until then a password-valid login yields an enrolment-only session.
  totpSecret   String?   @map("totp_secret")
  totpEnabled  Boolean   @default(false) @map("totp_enabled")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  auditLogs AdminAuditLog[]

  @@map("admin_users")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  adminUserId String   @map("admin_user_id") @db.Uuid
  // Free-form action string (e.g. "flag.set", "user.tier_changed",
  // "patient_data_viewed") — new actions need no migration.
  action      String
  // What the action touched. `targetType` is a coarse label
  // ("flag", "user", "admin_user"); `targetId` is a flag key OR a UUID,
  // so it is a plain string, not @db.Uuid.
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  // Structured before/after or context payload. Never holds patient
  // free-text — keeps the audit log safe to export.
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetId, createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}
