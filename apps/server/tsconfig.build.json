{
  "//": "Build-only config. Emits dist/ from src/ only. Run via `pnpm build`.",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "tests/**/*"],
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/domain-logic" }
  ]
}
