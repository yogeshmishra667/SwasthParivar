NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swasth_parivar?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-min-32-chars-development-only
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-dev-only
OTP_SECRET=change-me-otp-min-32-chars-development
ADMIN_JWT_SECRET=change-me-admin-jwt-min-32-chars-dev-only
ADMIN_JWT_REFRESH_SECRET=change-me-admin-refresh-jwt-min-32-chars-dev
# CSRF secret for /admin/auth (double-submit cookie via `csrf-csrf`).
ADMIN_CSRF_SECRET=change-me-admin-csrf-min-32-chars-development

# Claude API
CLAUDE_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=swasth-parivar-uploads

# Messaging
WHATSAPP_BUSINESS_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE_NAME=
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
MSG91_API_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# Push (Expo)
#
# IMPORTANT: this access token MUST belong to the same Expo project as
# the mobile app's eas.projectId (apps/mobile/app.json → extra.eas.projectId).
# A mismatch makes the Expo push API reject every send with
# `InvalidCredentials` even though tokens look fine on the server.
#
# Dev: leave UNSET. Expo accepts anonymous push (rate-limited but fine
#      for low-volume dev work).
# Prod: generate at https://expo.dev/accounts/<owner>/settings/access-tokens
#      using the account that owns the EAS project.
EXPO_ACCESS_TOKEN=

# Firebase Admin (only needed when auth.otp.provider flag = "firebase").
# Paste the entire JSON from Firebase Console → Project settings →
# Service accounts → Generate new private key, as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Observability
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# Payments (Phase 4)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
