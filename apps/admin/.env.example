# Base URL of the admin API. Leave empty in dev — `pnpm dev` proxies /admin
# to the local server (see vite.config.ts). Set to the server origin in
# production builds, e.g. https://api.swasthparivar.example.
VITE_API_BASE_URL=

# Dev-only: where the Vite proxy forwards /admin. Defaults to localhost:3000.
VITE_API_TARGET=http://localhost:3000
