{
  "name": "swasth-parivar",
  "private": true,
  "version": "0.1.0",
  "description": "Chronic condition health companion for Indian families.",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build && pnpm -r --filter=./apps/* run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r --parallel run typecheck",
    "lint": "pnpm -r --parallel run lint",
    "lint:fix": "pnpm -r --parallel run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "test": "pnpm -r --parallel run test",
    "test:unit": "pnpm --filter=@swasth/domain-logic run test",
    "test:integration": "pnpm --filter=@swasth/server run test:integration",
    "test:coverage": "pnpm -r --parallel run test:coverage",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "new-module": "bash scripts/scaffold/new-module.sh",
    "new-detector": "bash scripts/scaffold/new-detector.sh",
    "new-migration": "bash scripts/scaffold/new-migration.sh",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "@nozbe/with-observables>react": "*",
      "@nozbe/with-observables>@types/react": "*",
      "semver": "^7.7.4",
      "@xmldom/xmldom": "^0.8.13",
      "fast-uri": "^3.1.1",
      "fast-xml-builder": "^1.1.7",
      "protobufjs": "^7.5.6",
      "@protobufjs/utf8": "^1.1.1",
      "ip-address": "^10.1.1",
      "uuid": "^11.1.1",
      "postcss": "^8.5.10",
      "@hono/node-server": "^1.19.13",
      "@babel/runtime": "^7.26.10"
    }
  },
  "dependencies": {
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "danger": "^13.0.7",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "9.1.7",
    "lint-staged": "^16",
    "prettier": "^3.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.59.4",
    "vitest": "^4.1.4"
  }
}
